# Copy this file to .env and fill in the values.

# Required: Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Required: Discord application ID (numeric) from the Developer Portal
DISCORD_APP_ID=your-application-id-here

# Optional: how often to poll game servers for state changes (default: 60 seconds)
DEFAULT_POLL_INTERVAL_SECONDS=60

# Optional: logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: path to the SQLite database file (mount this path as a volume)
DB_PATH=/data/dom6bot.db
